{
  "name": "studyplug",
  "version": "0.1.1",
  "description": "TypeScript SDK for the StudyPlug educational content API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://docs.studyplug.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/9001-Solutions/study-plug-sdk"
  },
  "bugs": {
    "url": "https://github.com/9001-Solutions/study-plug-sdk/issues"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "studyplug",
    "education",
    "worksheets",
    "api",
    "sdk",
    "math",
    "reading",
    "science",
    "k-8",
    "curriculum",
    "content-generation",
    "edtech",
    "typescript"
  ]
}
